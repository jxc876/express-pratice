<%- include("partials/header") %>

<section class="hero">
  <p class="eyebrow">Public Area</p>
  <h1>An Express app with Auth</h1>
  <p>
    Visitors can browse public pages, create an account, log in, and access a
    protected members-only space.
  </p>
  <div class="actions">
    <% if (currentUser) { %>
      <a class="button" href="/members">Go to members area</a>
    <% } else { %>
      <a class="button" href="/signup">Create account</a>
      <a class="button secondary" href="/login">Log in</a>
    <% } %>
  </div>
</section>

<section class="panel-grid">
  <article>
    <h2>Public Content</h2>
    <p>The Home & About sections are open to everyone and do not require auth to view.</p>
  </article>
  <article>
    <h2>Members Only</h2>
    <p>The members page requires guests to log in before they can enter.</p>
  </article>
  <article>
    <h2><%= usersCount %> Members</h2>
    <p>Accounts are stored in memory for this starter version.</p>
  </article>
</section>

<%- include("partials/footer") %>
