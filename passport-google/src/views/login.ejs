<%- include("partials/header") %>

<section class="auth-card">
  <h1>Log in</h1>
  <% if (typeof error !== "undefined") { %>
    <p class="error"><%= error %></p>
  <% } %>
  <a class="button google-button" href="/auth/google">Continue with Google</a>
  <div class="auth-divider"><span>or</span></div>
  <form action="/login" method="post">
    <label>
      Email
      <input type="email" name="email" autocomplete="email" value="<%= form.email || "" %>" required>
    </label>
    <label>
      Password
      <input type="password" name="password" autocomplete="current-password" required>
    </label>
    <button class="button" type="submit">Log in</button>
  </form>
  <p class="auth-switch">Need an account? <a href="/signup">Sign up</a>.</p>
</section>

<%- include("partials/footer") %>
